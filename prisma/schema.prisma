generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  email           String    @unique
  /// "EMPLOYEE" | "MANAGEMENT"
  role            String
  phone           String?
  trade           String?
  defaultLocation String?
  passwordHash    String

  assignments     Assignment[]
  timeEntries     TimeEntry[]
  passwordResetTokens PasswordResetToken[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Project {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  customer    String?
  contact     String?
  address     String
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  /// "ACTIVE" | "COMPLETED" | "ON_HOLD" | "ARCHIVED"
  status      String         @default("ACTIVE")

  assignments Assignment[]
  timeEntries TimeEntry[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Assignment {
  id           Int      @id @default(autoincrement())
  date         DateTime
  /// Multiple assignments per user/day are allowed.
  type         String   @default("DEFAULT")

  user         User           @relation(fields: [userId], references: [id])
  userId       Int

  project      Project?       @relation(fields: [projectId], references: [id])
  projectId    Int?

  startTime    String?
  endTime      String?
  workType     String?
  meetingPoint String?
  notes        String?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

/// Tracks actual clock-in / clock-out sessions per employee.
/// A null clockedOutAt means the session is currently active.
/// Task switches are represented as a closed entry + a new entry.
model TimeEntry {
  id           Int       @id @default(autoincrement())
  user         User      @relation(fields: [userId], references: [id])
  userId       Int
  project      Project   @relation(fields: [projectId], references: [id])
  projectId    Int
  /// Work type for this session, e.g. "Electrical", "Cleaning", "Labor"
  workType     String
  clockedInAt  DateTime  @default(now())
  clockedOutAt DateTime?
  notes        String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique

  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

