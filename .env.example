# Copy this file to .env and fill in real values for local dev.
# For Vercel: add each variable in Project → Settings → Environment Variables.

# Database (required for Vercel – use Postgres; locally SQLite in prisma/dev.db)
# Get from: Vercel Storage (Postgres), Neon, Supabase, Railway, etc.
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: override demo user password for demo@odetaa.com (default: VercelDemo123!)
# VERCEL_DEMO_PASSWORD="YourCustomDemoPassword"

# Optional: SMTP for assignment notification emails (if unset, no emails are sent)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="user"
# SMTP_PASS="password"
# SMTP_FROM="OD Scheduler <noreply@yourdomain.com>"
